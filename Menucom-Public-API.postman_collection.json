    {
      "name": "Payments",
      "item": [
        {
          "name": "Webhook - Payment Notifications",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-signature", "value": "{{mp_signature}}", "description": "Firma HMAC del webhook" },
              { "key": "x-request-id", "value": "{{$guid}}" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"payment.created\",\n  \"api_version\": \"v1\",\n  \"data\": {\n    \"id\": \"123456789\"\n  },\n  \"date_created\": \"2025-01-01T00:00:00Z\",\n  \"id\": 123456,\n  \"live_mode\": false,\n  \"type\": \"payment\",\n  \"user_id\": \"123456789\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/webhooks",
              "host": ["{{base_url}}"],
              "path": ["payments", "webhooks"]
            }
          }
        },
        {
          "name": "OAuth Callback (POST)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorizationCode\": \"TG-1234567890-A1B2C3D4\",\n  \"redirectUri\": \"http://localhost:3000/payments/oauth/callback\",\n  \"vinculation_id\": \"uuid_de_vinculacion\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/oauth/callback",
              "host": ["{{base_url}}"],
              "path": ["payments", "oauth", "callback"]
            }
          }
        },
        {
          "name": "OAuth Callback (GET - Redirect)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/payments/oauth/callback?code=TG-1234567890-A1B2C3D4&state=uuid_state",
              "host": ["{{base_url}}"],
              "path": ["payments", "oauth", "callback"],
              "query": [
                { "key": "code", "value": "TG-1234567890-A1B2C3D4" },
                { "key": "state", "value": "uuid_state" }
              ]
            }
          }
        },
        {
          "name": "OAuth Config Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/payments/oauth/config-check",
              "host": ["{{base_url}}"],
              "path": ["payments", "oauth", "config-check"]
            }
          }
        }
